
# Personal Finance AI - Configuration File



# AI Provider Configuration
# Choose your AI provider: "ollama" or "lmstudio"
AI_PROVIDER=ollama


# Ollama Configuration (Default provider)

# Host where Ollama is running (default works for Docker Desktop on Mac/Windows)
OLLAMA_HOST=http://host.docker.internal:11434

# Model for chat/LLM tasks (Granite 4 is recommended for this app)
OLLAMA_MODEL=granite4:latest

# Model for embeddings (768 dimensions)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe


# LM Studio Configuration (OpenAI-compatible API)
# Host where LM Studio is running (default: http://localhost:1234)
# Note: Use host.docker.internal:1234 if running LM Studio on the host machine
LMSTUDIO_HOST=http://host.docker.internal:1234

# Model name (this should match what you load in LM Studio)
LMSTUDIO_MODEL=qwen/qwen3-vl-8b

# Model for embeddings (may not be supported by all LM Studio models)
LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v2-moe

# API key (LM Studio uses "lm-studio" by default)
LMSTUDIO_API_KEY=lm-studio


# Embedding Provider Configuration
# You can use a different provider for embeddings than for chat
# Options: "ollama" or "lmstudio"
EMBEDDING_PROVIDER=ollama


# Vector Database Configuration
# Vector size depends on your embedding model:
# - nomic-embed-text-v2-moe: 768
# - text-embedding-ada-002: 1536
# - all-MiniLM-L6-v2: 384
VECTOR_SIZE=768


# Qdrant Configuration (usually don't need to change)

QDRANT_HOST=qdrant
QDRANT_PORT=6333
